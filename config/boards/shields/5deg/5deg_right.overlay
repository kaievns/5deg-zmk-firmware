#include "5deg.dtsi"
#include <dt-bindings/led/led.h>

&default_transform {
    col-offset = <5>;
};

/* --- RGB underglow (16 LEDs on right) --- */

&spi0 {
    led_strip: ws2812@0 {
        compatible = "worldsemi,ws2812-spi";
        reg = <0>;
        spi-max-frequency = <4000000>;
        spi-one-frame = <0x70>;
        spi-zero-frame = <0x40>;
        chain-length = <16>;
        color-mapping = <LED_COLOR_ID_GREEN LED_COLOR_ID_RED LED_COLOR_ID_BLUE>;
    };
};

/ {
    chosen {
        zmk,underglow = &led_strip;
    };
};

/* --- Trackball (PMW3610) — GPIO bit-bang 3-wire SPI --- */

/ {
    trackball: pmw3610 {
        compatible = "pixart,pmw3610";
        cs-gpios     = <&gpio1 15 GPIO_ACTIVE_LOW>;
        clk-gpios    = <&gpio1 10 0>;
        sdio-gpios   = <&gpio1 13 0>;
        motion-gpios = <&gpio1 11 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        cpi          = <800>;
    };
};

/* Connect trackball to split input bridge */
&split_input {
    device = <&trackball>;
};
